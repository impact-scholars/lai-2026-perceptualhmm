@article{ScherbaumSingleDecisionsSequential2022,
  title = {From Single Decisions to Sequential Choice Patterns: {{Extending}} the Dynamics of Value-Based Decision-Making},
  shorttitle = {From Single Decisions to Sequential Choice Patterns},
  author = {Scherbaum, Stefan and Lade, Steven J. and Siegmund, Stefan and Goschke, Thomas and Dshemuchadse, Maja},
